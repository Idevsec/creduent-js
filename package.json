{
    "name": "@idevsec/creduent",
    "version": "2.0.7",
    "type": "module",
    "description": "The official JS/TS SDK for Creduent: the open standard and security protocol for cryptographic AI agent identity, authentication, and trust verification using Ed25519 and DNS.",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "exports": {
        ".": {
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            },
            "import": {
                "types": "./dist/esm/index.d.ts",
                "default": "./dist/esm/index.js"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build:esm": "tsc",
        "build:cjs": "tsc -p tsconfig.cjs.json",
        "build": "npm run build:esm && npm run build:cjs",
        "test": "node --test test/test.mjs",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "creduent",
        "ai-agent",
        "agent-identity",
        "agent-trust",
        "agent-verification",
        "agent-security",
        "agent-auth",
        "autonomous-agents",
        "cryptographic-signing",
        "ed25519",
        "attestation-registry",
        "dns-verification",
        "mcp",
        "model-context-protocol",
        "crewai",
        "langgraph",
        "idevsec"
    ],
    "author": "IDevSec",
    "license": "Apache-2.0",
    "devDependencies": {
        "@types/node": "^26.0.0",
        "typescript": "^7.0.2"
    },
    "dependencies": {
        "zod": "^4.4.3"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/idevsec/creduent-js"
    },
    "homepage": "https://github.com/idevsec/creduent-js#readme"
}
